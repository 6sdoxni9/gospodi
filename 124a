mkdir -p /mnt/cdrom
mount /dev/sr0 /mnt/cdrom

mariadb -e "CREATE DATABASE webdb;"
mariadb -e "CREATE USER 'webc'@'localhost' IDENTIFIED BY 'P@ssw0rd';"
mariadb -e "GRANT ALL PRIVILEGES ON webdb.* TO 'webc'@'localhost';"
